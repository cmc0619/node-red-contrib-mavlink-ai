  {
    "id": "fw_sep",
    "type": "function",
    "z": "fleetwringer",
    "name": "Separation monitor",
    "func": "// Track each system's latest position and alarm when the closest pair of\n// drones drops below the collision floor. Positions carry a receive time so a\n// vehicle whose telemetry has stopped is pruned — a frozen position must never\n// keep reporting 'safe'. Flat-earth (equirectangular) distance around the\n// local latitude, accurate well under 1% at these ranges.\nconst FLOOR_M = 8;\nconst FRESH_MS = 3000; // drop a vehicle not heard from within this window\nconst R = 6378137; // WGS84 equatorial radius, m\nconst now = Date.now();\n\nconst fleet = context.get('fleet') || {};\nconst p = msg.payload;\nif (p && p.name === 'GLOBAL_POSITION_INT' && p.fields) {\n    fleet[p.sysid] = {\n        lat: p.fields.lat / 1e7,\n        lon: p.fields.lon / 1e7,\n        alt: p.fields.alt / 1000,\n        t: now\n    };\n}\n\n// Expire stale vehicles so a dead link cannot keep the fleet looking safe.\nfor (const id of Object.keys(fleet)) {\n    if (now - fleet[id].t > FRESH_MS) { delete fleet[id]; }\n}\ncontext.set('fleet', fleet);\n\nconst ids = Object.keys(fleet);\nif (ids.length < 2) {\n    node.status({ fill: 'grey', shape: 'ring', text: ids.length + ' fresh vehicle(s)' });\n    return null;\n}\n\nlet min = Infinity;\nlet pair = null;\nfor (let i = 0; i < ids.length; i++) {\n    for (let j = i + 1; j < ids.length; j++) {\n        const a = fleet[ids[i]];\n        const b = fleet[ids[j]];\n        const north = ((b.lat - a.lat) * Math.PI / 180) * R;\n        const east = ((b.lon - a.lon) * Math.PI / 180) * R * Math.cos(a.lat * Math.PI / 180);\n        const down = a.alt - b.alt;\n        const d = Math.sqrt(north * north + east * east + down * down);\n        if (d < min) { min = d; pair = [ids[i], ids[j]]; }\n    }\n}\n\nconst safe = min >= FLOOR_M;\nnode.status({\n    fill: safe ? 'green' : 'red',\n    shape: 'dot',\n    text: 'min sep ' + min.toFixed(1) + ' m ' + (safe ? 'ok' : 'BREACH') + ' (' + pair.join('/') + ')'\n});\nmsg.payload = { minSeparationM: Number(min.toFixed(2)), closestPair: pair, floorM: FLOOR_M, safe: safe, freshVehicles: ids.length };\nif (!safe) { node.warn('Separation breach: ' + min.toFixed(1) + ' m between ' + pair.join(' and ')); }\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 400,
    "y": 200,
    "wires": [
      [
        "fw_sep_dbg"
      ]
    ]
  },
